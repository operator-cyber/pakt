\fs29\fsmilli14875 \cf9 \cb4 \strokec9 import\cf6 \strokec6  \{ Crypto \} \cf9 \strokec9 from\cf6 \strokec6  \cf11 \strokec11 '@perfood/capacitor-crypto-api'\cf6 \strokec6 ;\
\
\cf9 \strokec9 const\cf6 \strokec6  performHardwareSignature = \cf9 \strokec9 async\cf6 \strokec6  (documentHash: \cf12 \strokec12 string\cf6 \strokec6 ) => \{\
  \cf9 \strokec9 try\cf6 \strokec6  \{\
    \cf9 \strokec9 const\cf6 \strokec6  \{ isAvailable \} = \cf9 \strokec9 await\cf6 \strokec6  Crypto.isBiometricsEnabled();\
    \cf9 \strokec9 if\cf6 \strokec6  (!isAvailable) \cf9 \strokec9 throw\cf6 \strokec6  \cf9 \strokec9 new\cf6 \strokec6  \cf12 \strokec12 Error\cf6 \strokec6 (\cf11 \strokec11 "Hardware biometrics unavailable"\cf6 \strokec6 );\
\
    \cf8 \strokec8 // This triggers the native Face ID / Secure Intent flow\cf6 \strokec6 \
    \cf9 \strokec9 const\cf6 \strokec6  result = \cf9 \strokec9 await\cf6 \strokec6  Crypto.sign(\{\
      \cf10 \strokec10 tag\cf6 \strokec6 : \cf11 \strokec11 'pakt-nda-signer-key'\cf6 \strokec6 ,\
      \cf10 \strokec10 data\cf6 \strokec6 : documentHash, \cf8 \strokec8 // Base64 or Hex hash of the NDA\cf6 \strokec6 \
      \cf10 \strokec10 type\cf6 \strokec6 : \cf11 \strokec11 'FACE_ID'\cf6 \strokec6 \
    \});\
\
    \cf9 \strokec9 return\cf6 \strokec6  result.signature; \cf8 \strokec8 // ASN.1 DER encoded signature\cf6 \strokec6 \
  \} \cf9 \strokec9 catch\cf6 \strokec6  (error) \{\
    \cf12 \strokec12 console\cf6 \strokec6 .error(\cf11 \strokec11 "Biometric signature failed"\cf6 \strokec6 , error);\
  \}\
\};\
